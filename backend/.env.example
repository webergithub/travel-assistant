# 后端配置 —— 复制为 .env 后填写

# 服务端口（本地开发 4100；线上 3400）
PORT=4100

# JWT 签名密钥（生产务必改成随机长字符串）
JWT_SECRET=change-me-to-a-long-random-secret

# 平台统一代付的 Claude API Key（留空则用户必须自带 key）
ANTHROPIC_API_KEY=

# 默认模型
ANTHROPIC_MODEL=claude-opus-4-8

# 数据库（SQLite 开发；生产可换 Postgres 连接串）
DATABASE_URL="file:./dev.db"

# 允许的前端来源（CORS）
CORS_ORIGIN=http://localhost:5181
